digraph G {
    node [shape=box];

    a [label="Stage IV mNSCLC with BRAF V600 mutation"];
    b [label="Dabrafenib-trametinib [III, A; MCBS 2; ESCAT I-B]"];
    c [label="Disease_progression"];
    d [label="Oligoprogression"];
    e [label="Local treatment (surgery or RT) and continue targeted systemic treatment [IV, C]"];
    f [label="Systemic_progression"];
    g [label="no_smoking_history"];
    h [label="platinum-based ChT +/- immunotherapy [IV, A]"];
    i [label="smoking_history"];
    j [label="immunotherapy +/- platinum-based ChT [IV, B]\nDabrafenib-trametinib if not received in first line [III, A; MCBS 2; ESCAT I-B]"];

    a -> b;
    b -> c;
    c -> d;
    c -> f;
    d -> e;
    e -> f;
    f -> g;
    f -> i;
    g -> h;
    i -> j;
}